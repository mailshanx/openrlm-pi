{
	"name": "arcgeneral-pi",
	"version": "0.1.0",
	"description": "Pi extension for arcgeneral — a recursive LLM agent with persistent IPython REPL",
	"keywords": [
		"pi-package"
	],
	"license": "MIT",
	"peerDependencies": {
		"@mariozechner/pi-coding-agent": "*",
		"@sinclair/typebox": "*"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@mariozechner/pi-coding-agent": "^0.54.0",
		"@sinclair/typebox": "^0.34.48",
		"@types/node": "^25.3.0",
		"eslint": "^10.0.1",
		"eslint-config-prettier": "^10.1.8",
		"prettier": "^3.8.1",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.56.0"
	},
	"scripts": {
		"lint": "eslint .",
		"lint:fix": "eslint --fix .",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"typecheck": "tsc --noEmit"
	},
	"pi": {
		"extensions": [
			"./extensions"
		]
	}
}
